# --- Python ---
__pycache__/
*.pyc
venv/
.venv/
.mypy_cache/

# --- Node / frontend build (frontend/ has its own .gitignore too) ---
node_modules/
dist/
dist-ssr/
*.local

# --- Secrets & local config (never ship) ---
*.env
*.db

# --- Editor / OS cruft ---
.vscode/
.idea/
.DS_Store
**/.DS_Store

# --- Markdown / planning docs (not shipped to production) ---
*.md
